rules_version = '2';

// Firestore Security Rules — produção
//
// Cole o conteúdo abaixo em:
//   Firebase Console → Firestore Database → Rules
//
// Antes de colar, ATUALIZE a função `isAdmin()` com o UID
// real da conta admin (Authentication → Users → coluna User UID).

service cloud.firestore {
  match /databases/{database}/documents {

    // Verifica se o request é do admin autenticado.
    // Substitua o UID pelo seu (mesmo valor de NEXT_PUBLIC_ADMIN_UID).
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == 'm9GLhNQbNZRbwFT3l6M8XiJSIpF3';
    }

    // ─────────────────────────────────────────────────────────
    // POSTS
    //   Leitura pública: só posts com `published == true`.
    //   Admin: leitura total + escrita.
    // ─────────────────────────────────────────────────────────
    match /posts/{postId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // PROJECTS
    //   Leitura pública total (sem flag de "published" no schema).
    //   Admin: escrita.
    // ─────────────────────────────────────────────────────────
    match /projects/{projectId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // GAMES
    //   Leitura pública: só games com `published == true`.
    //   Admin: leitura total + escrita.
    // ─────────────────────────────────────────────────────────
    match /games/{gameId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // BOOKS
    //   Leitura pública: só books com `published == true`.
    //   Admin: leitura total + escrita.
    // ─────────────────────────────────────────────────────────
    match /books/{bookId} {
      allow read: if resource.data.published == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ─────────────────────────────────────────────────────────
    // GUESTBOOK
    //   Leitura pública: qualquer um vê todas mensagens.
    //   Escrita: user autenticado pode criar/editar/deletar SÓ a própria
    //     entrada (docId === auth.uid).
    //   Admin: pode deletar qualquer entrada (moderação de spam).
    //   Validação: message não vazia, máx 280 chars.
    // ─────────────────────────────────────────────────────────
    match /guestbook/{userId} {
      allow read: if true;
      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == userId
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 280;
      allow delete: if isAdmin()
        || (request.auth != null && request.auth.uid == userId);
    }

    // Default: nega tudo (defense in depth).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
